# Copy to .env and adjust. Never commit real secrets.

TIQORA_ENV=development
TIQORA_DEBUG=true
TIQORA_LOG_LEVEL=INFO
TIQORA_SECRET_KEY=dev-only-change-me

# Use one of:
DATABASE_URL=postgresql+asyncpg://tiqora:tiqora@localhost:5432/tiqora
# DATABASE_URL=mysql+aiomysql://tiqora:tiqora@localhost:3306/tiqora

REDIS_URL=redis://localhost:6379/0
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=tiqora-dev-master-key

TIQORA_CORS_ORIGINS=http://localhost:5173,http://localhost:8000
TIQORA_SCHEMA_OWNERSHIP=false
